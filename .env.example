# Backend
# Port 5433 matches docker-compose.yml; change to 5432 if using an existing PostgreSQL instance
DATABASE_URL="postgresql://pulse:pulse_secret@localhost:5433/aipulse"
GROQ_API_KEY=your_groq_api_key_here
PORT=3001
FRONTEND_URL=http://localhost:5173

# Frontend (prefix with VITE_ to expose to the browser)
VITE_API_URL=http://localhost:3001
